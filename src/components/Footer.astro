---
import { execSync } from 'node:child_process';
import { SITE, type Lang } from '../data/site';
import { services } from '../data/services';
import { useTranslations } from '../i18n/ui';
import CommentaryToggle from './CommentaryToggle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

// Último commit real en build time; sin .git (deploy CLI) se omite
let lastCommit = '';
try {
  lastCommit = execSync('git log -1 --format=%h', { encoding: 'utf8' }).trim();
} catch {
  lastCommit = '';
}
---

<footer class="footer">
  <div class="footer-wordmark-wrap" aria-hidden="true">
    <p class="footer-wordmark" data-footer-wordmark>
      mkcodev<span class="footer-wordmark-cursor">_</span>
    </p>
  </div>
  {
    lang === 'es' && (
      <nav class="container-site footer-nav" aria-label="secundaria">
        <div class="footer-nav-col">
          <p class="footer-nav-title">
            <span aria-hidden="true">$</span> ls servicios/
          </p>
          <ul class="footer-nav-list">
            {services.map((service) => (
              <li>
                <a href={`/servicios/${service.slug}`}>{service.shortTitle}</a>
              </li>
            ))}
            <li>
              <a href="/servicios">todos los servicios →</a>
            </li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-title">
            <span aria-hidden="true">$</span> ls zonas/
          </p>
          <ul class="footer-nav-list">
            <li>
              <a href="/diseno-web-bilbao">diseño web en Bilbao</a>
            </li>
            <li>
              <a href="/diseno-web-zamora">diseño web en Zamora</a>
            </li>
            <li>
              <a href="/blog">blog</a>
            </li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-title">
            <span aria-hidden="true">$</span> cat legal.md
          </p>
          <ul class="footer-nav-list">
            <li>
              <a href="/aviso-legal">aviso legal</a>
            </li>
            <li>
              <a href="/privacidad">privacidad</a>
            </li>
            <li>
              <a href="/cookies">cookies</a>
            </li>
          </ul>
        </div>
        <div class="footer-nav-col">
          <p class="footer-nav-title">
            <span aria-hidden="true">$</span> cat contacto.md
          </p>
          <address class="footer-nap">
            <span>{SITE.author}</span>
            <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a>
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
            <span>Basauri · Bilbao · Zamora</span>
          </address>
        </div>
      </nav>
    )
  }
  <div class="container-site footer-grid">
    <div class="footer-col">
      <p class="footer-brand">mkcodev<span class="footer-cursor" aria-hidden="true">_</span></p>
      <p class="footer-meta">
        © {year} · {SITE.author} · Bilbao
      </p>
    </div>

    <ul class="footer-links">
      <li><a href={SITE.github} rel="noopener" target="_blank">GitHub</a></li>
      <li><a href={SITE.linkedin} rel="noopener" target="_blank">LinkedIn</a></li>
      <li><a href={`mailto:${SITE.email}`}>Email</a></li>
      <li><a href="/resume.json" data-astro-reload>{t('footer.machineReadable')}</a></li>
    </ul>

    <div class="footer-col footer-col--right">
      <p class="footer-meta" data-footer-build>
        {t('footer.builtWith')}{lastCommit && ` · ${t('footer.lastCommit')} `}{
          lastCommit && <span class="footer-commit">{lastCommit}</span>
        }
      </p>
      <p class="footer-hint">{t('footer.hint')}</p>
      <CommentaryToggle lang={lang} />
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border-soft);
    padding-block: 2.5rem;
    margin-top: clamp(4rem, 10vw, 7.5rem);
    overflow: hidden;
  }
  /* Wordmark tone-on-tone: firma sin gritar. Entrada por scroll con
     translateY. La animación va con CSS clásica (transition + class por
     IntersectionObserver del reveals) porque no depende del grafo GSAP. */
  .footer-wordmark-wrap {
    width: 100%;
    padding-inline: 0;
    line-height: 0;
    margin-bottom: 2rem;
    user-select: none;
  }
  .footer-wordmark {
    display: block;
    margin: 0;
    padding-inline: clamp(1rem, 3vw, 3rem);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(4rem, 14vw, 12rem);
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--color-surface-2);
    white-space: nowrap;
    overflow: hidden;
  }
  .footer-wordmark-cursor {
    color: var(--color-accent);
    animation: blink 1.1s steps(1) infinite;
  }
  .footer-nav {
    display: grid;
    gap: 2rem;
    padding-bottom: 2.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border-soft);
  }
  @media (min-width: 700px) {
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .footer-nav {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .footer-nav-title {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
  }
  .footer-nav-title span {
    color: var(--color-accent);
  }
  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .footer-nav-list a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-hover) ease;
  }
  .footer-nav-list a:hover,
  .footer-nav-list a:focus-visible {
    color: var(--color-accent);
  }
  .footer-nap {
    display: grid;
    gap: 0.4rem;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .footer-nap a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-hover) ease;
  }
  .footer-nap a:hover,
  .footer-nap a:focus-visible {
    color: var(--color-accent);
  }

  .footer-grid {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
    }
  }
  .footer-brand {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-body);
    color: var(--color-text);
  }
  .footer-cursor {
    color: var(--color-accent);
    animation: blink 1.2s steps(1) infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .footer-meta {
    margin: 0.25rem 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
  }
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .footer-links a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-hover) ease;
  }
  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--color-accent);
  }
  .footer-col--right {
    text-align: left;
  }
  @media (min-width: 900px) {
    .footer-col--right {
      text-align: right;
    }
  }
  .footer-commit {
    color: var(--color-accent-dark);
  }
  .footer-hint {
    margin: 0.25rem 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    /* --color-ink-deep no llega a 4.5:1 sobre el fondo (AA) */
    color: var(--color-muted);
  }
</style>
