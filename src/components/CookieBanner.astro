---
import type { Lang } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const text =
  lang === 'es'
    ? {
        body: 'Uso cookies de analítica (GA4) solo si las aceptas — nada de publicidad ni terceros raros.',
        more: 'más info',
        accept: 'aceptar',
        reject: 'rechazar',
        label: 'Aviso de cookies',
      }
    : {
        body: 'I use analytics cookies (GA4) only if you accept — no ads, no shady third parties.',
        more: 'more info',
        accept: 'accept',
        reject: 'reject',
        label: 'Cookie notice',
      };
---

<div class="cookie-banner" data-cookie-banner role="region" aria-label={text.label} hidden>
  <p class="cookie-banner-text">
    <span class="cookie-banner-prompt" aria-hidden="true">$</span>
    {text.body}
    <a href="/cookies">{text.more}</a>
  </p>
  <div class="cookie-banner-actions">
    <button type="button" class="btn-terminal btn-terminal--primary" data-consent-accept>
      <span class="bracket bracket-l" aria-hidden="true">[</span>
      {text.accept}
      <span class="bracket bracket-r" aria-hidden="true">]</span>
    </button>
    <button type="button" class="btn-terminal" data-consent-reject>
      {text.reject}
    </button>
  </div>
</div>

<style>
  /* Superficie SÓLIDA (glass no permitido fuera de navbar/menu/bento/⌘K) */
  .cookie-banner {
    position: fixed;
    inset-inline: 1rem;
    bottom: 1rem;
    z-index: 180;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    max-width: 640px;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
  }
  @media (min-width: 700px) {
    .cookie-banner {
      inset-inline: auto 1.5rem;
      bottom: 1.5rem;
    }
  }

  .cookie-banner-text {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text);
  }
  .cookie-banner-prompt {
    color: var(--color-accent);
  }
  .cookie-banner-text a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--duration-hover) ease;
  }
  .cookie-banner-text a:hover,
  .cookie-banner-text a:focus-visible {
    color: var(--color-white);
  }

  .cookie-banner-actions {
    display: flex;
    gap: 0.75rem;
  }
</style>
