---
import SectionHeading from '../SectionHeading.astro';
import { useTranslations } from '../../i18n/ui';
import { SITE, type Lang } from '../../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const lead =
  lang === 'es'
    ? '¿Un proyecto, una vacante o solo hablar de webs rápidas? Mi inbox compila.'
    : 'A project, a role, or just fast-websites talk? My inbox compiles.';
---

<section id="contacto" class="container-site section-block">
  <SectionHeading marker={t('section.contact')} title={lang === 'es' ? 'Contacto' : 'Contact'} />

  <div class="contact" data-reveal-group>
    <p class="contact-lead" data-reveal>{lead}</p>

    <p class="contact-cmd" data-reveal aria-hidden="true">
      <span class="contact-prompt">$</span> mail -s "hola" {SITE.email}
    </p>

    <div class="contact-actions" data-reveal>
      <a
        class="btn-terminal btn-terminal--primary contact-mail"
        href={`mailto:${SITE.email}`}
        data-magnetic
      >
        <span class="bracket bracket-l">[</span>
        {SITE.email}
        <span class="bracket bracket-r">]</span>
      </a>
    </div>

    <ul class="contact-links" data-reveal>
      <li>
        <a href={SITE.github} rel="noopener" target="_blank" data-magnetic>GitHub ↗</a>
      </li>
      <li>
        <a href={SITE.linkedin} rel="noopener" target="_blank" data-magnetic>LinkedIn ↗</a>
      </li>
      <li>
        <a href={SITE.cvPath} download data-astro-reload data-magnetic>
          {lang === 'es' ? 'CV.pdf ↓' : 'Resume.pdf ↓'}
        </a>
      </li>
    </ul>
  </div>
</section>

<style>
  .section-block {
    padding-block: clamp(4rem, 10vw, 7.5rem) 0;
  }

  .contact-lead {
    margin: 0 0 1.5rem;
    max-width: 560px;
    font-size: var(--text-h3);
    line-height: var(--text-h3--line-height);
    color: var(--color-text);
  }
  .contact-cmd {
    margin: 0 0 2rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    overflow-wrap: anywhere;
  }
  .contact-prompt {
    color: var(--color-accent);
  }

  .contact-actions {
    margin-bottom: 2rem;
  }
  .contact-mail {
    font-size: var(--text-body);
    padding: 0.875rem 1.5rem;
    will-change: transform;
  }

  .contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.75rem;
  }
  .contact-links a {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.375rem 0;
    will-change: transform;
    transition: color var(--duration-hover) ease;
  }
  .contact-links a:hover,
  .contact-links a:focus-visible {
    color: var(--color-accent);
  }
</style>
