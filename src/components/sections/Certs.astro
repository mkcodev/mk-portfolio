---
import SectionHeading from '../SectionHeading.astro';
import { useTranslations } from '../../i18n/ui';
import { certs } from '../../data/certs';
import type { Lang } from '../../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="certificaciones" class="container-site section-block">
  <SectionHeading
    marker={t('section.certs')}
    title={lang === 'es' ? 'Certificaciones' : 'Certifications'}
  />

  <ul class="certs-grid" data-reveal-group>
    {
      certs.map((c) => (
        <li class="cert" data-reveal>
          <div class="cert-head">
            <h3 class="cert-name">{c.name}</h3>
            {c.year && <span class="cert-year">{c.year}</span>}
          </div>
          <p class="cert-issuer">{c.issuer}</p>
          {c.verifyUrl && (
            <a class="cert-verify" href={c.verifyUrl} rel="noopener" target="_blank">
              {lang === 'es' ? 'verificar' : 'verify'} ↗
            </a>
          )}
          {c.inProgress && c.note && <span class="cert-badge">{c.note[lang]}</span>}
        </li>
      ))
    }
  </ul>
</section>

<style>
  .section-block {
    padding-block: clamp(4rem, 10vw, 7.5rem) 0;
  }

  .certs-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .certs-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 1024px) {
    .certs-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .cert {
    position: relative;
    padding: 1.125rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    transition:
      border-color var(--duration-hover) ease,
      box-shadow var(--duration-hover) ease;
  }
  .cert:hover,
  .cert:focus-within {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-card);
  }

  .cert-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .cert-name {
    margin: 0;
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-white);
  }
  .cert-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
  }
  .cert-issuer {
    margin: 0.25rem 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
  }
  .cert-verify {
    display: inline-block;
    margin-top: 0.625rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent-dark);
    text-decoration: none;
    transition: color var(--duration-hover) ease;
  }
  .cert-verify:hover,
  .cert-verify:focus-visible {
    color: var(--color-accent);
  }
  .cert-badge {
    position: absolute;
    top: 0.875rem;
    right: 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-dark);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.5rem;
  }
  .cert:has(.cert-badge) .cert-year {
    display: none;
  }
</style>
