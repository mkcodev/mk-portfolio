---
import Base from '../layouts/Base.astro';
import Hero from '../components/sections/Hero.astro';
import Projects from '../components/sections/Projects.astro';
import Bento from '../components/sections/Bento.astro';
import Timeline from '../components/sections/Timeline.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { useTranslations } from '../i18n/ui';

const lang = 'es' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title={t('meta.home.title')} description={t('meta.home.description')}>
  <Hero lang={lang} />

  <Projects lang={lang} />

  <Bento lang={lang} />

  <Timeline lang={lang} />

  <section id="sobre-mi" class="container-site section-block">
    <SectionHeading marker={t('section.about')} title="Sobre mí" />
  </section>

  <section id="contacto" class="container-site section-block">
    <SectionHeading marker={t('section.contact')} title="Contacto" />
  </section>
</Base>

<style>
  .section-block {
    padding-block: clamp(4rem, 10vw, 7.5rem) 0;
  }
</style>
